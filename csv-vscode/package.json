{
  "name": "csv-adapter",
  "displayName": "CSV Adapter",
  "description": "CSV Adapter integration for VS Code - syntax highlighting, snippets, IntelliSense, wallet explorer, and proof visualizer",
  "version": "0.1.0",
  "publisher": "csv-adapter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/csv-adapter/csv-adapter"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onLanguage:rust",
    "onLanguage:typescript",
    "workspaceContains:**/csv-adapter/**"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "csv-proof",
        "aliases": ["CSV Proof", "csv-proof"],
        "extensions": [".csv-proof"],
        "icon": {
          "light": "./icons/csv-icon.svg",
          "dark": "./icons/csv-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "csv-proof",
        "scopeName": "source.csv-proof",
        "path": "./syntaxes/csv.tmLanguage.json"
      },
      {
        "injectTo": [
          "source.rust",
          "source.ts",
          "source.tsx",
          "source.js"
        ],
        "scopeName": "source.csv-injection",
        "path": "./syntaxes/csv.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "rust",
        "path": "./snippets/csv.code-snippets"
      },
      {
        "language": "typescript",
        "path": "./snippets/csv.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "csv.createRight",
        "title": "CSV: Create Right",
        "description": "Create a new CSV Right",
        "category": "CSV",
        "icon": "$(add)"
      },
      {
        "command": "csv.transferCrossChain",
        "title": "CSV: Transfer Cross-Chain",
        "description": "Initiate a cross-chain transfer",
        "category": "CSV",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "csv.inspectProof",
        "title": "CSV: Inspect Proof",
        "description": "Open the proof visualizer",
        "category": "CSV",
        "icon": "$(graph)"
      },
      {
        "command": "csv.checkBalance",
        "title": "CSV: Check Wallet Balance",
        "description": "Check wallet balance across chains",
        "category": "CSV",
        "icon": "$(credit-card)"
      },
      {
        "command": "csv.openDocumentation",
        "title": "CSV: Open Documentation",
        "description": "Open CSV Adapter documentation",
        "category": "CSV",
        "icon": "$(book)"
      },
      {
        "command": "csv.runTutorial",
        "title": "CSV: Run Tutorial",
        "description": "Run the CSV Adapter tutorial",
        "category": "CSV",
        "icon": "$(play)"
      },
      {
        "command": "csv.refreshWalletExplorer",
        "title": "CSV: Refresh Wallet Explorer",
        "description": "Refresh the wallet explorer view",
        "category": "CSV",
        "icon": "$(refresh)"
      },
      {
        "command": "csv.copyRightId",
        "title": "CSV: Copy Right ID",
        "description": "Copy Right ID to clipboard",
        "category": "CSV",
        "icon": "$(clippy)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "csv-explorer",
          "title": "CSV Adapter",
          "icon": "$(hub)"
        }
      ]
    },
    "views": {
      "csv-explorer": [
        {
          "id": "csvWalletExplorer",
          "name": "Wallet Explorer",
          "icon": "$(wallet)",
          "contextualTitle": "CSV Adapter Wallet"
        },
        {
          "id": "csvProofVisualizer",
          "name": "Proof Visualizer",
          "icon": "$(graph)",
          "contextualTitle": "CSV Proof Visualizer"
        }
      ]
    },
    "configuration": {
      "title": "CSV Adapter",
      "properties": {
        "csv.chains": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ethereum",
              "bitcoin",
              "aptos",
              "sui",
              "solana"
            ]
          },
          "default": ["ethereum", "aptos", "sui"],
          "description": "List of configured chains for CSV Adapter",
          "scope": "window"
        },
        "csv.network": {
          "type": "string",
          "enum": ["mainnet", "testnet", "devnet"],
          "default": "testnet",
          "description": "Network environment for CSV operations",
          "scope": "window"
        },
        "csv.rpc.ethereum": {
          "type": "string",
          "default": "",
          "description": "Custom RPC endpoint for Ethereum",
          "scope": "window"
        },
        "csv.rpc.bitcoin": {
          "type": "string",
          "default": "",
          "description": "Custom RPC endpoint for Bitcoin",
          "scope": "window"
        },
        "csv.rpc.aptos": {
          "type": "string",
          "default": "",
          "description": "Custom RPC endpoint for Aptos",
          "scope": "window"
        },
        "csv.rpc.sui": {
          "type": "string",
          "default": "",
          "description": "Custom RPC endpoint for Sui",
          "scope": "window"
        },
        "csv.rpc.solana": {
          "type": "string",
          "default": "",
          "description": "Custom RPC endpoint for Solana",
          "scope": "window"
        },
        "csv.wallet.path": {
          "type": "string",
          "default": "",
          "description": "Path to the wallet file for CSV operations",
          "scope": "window"
        },
        "csv.logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "description": "Logging verbosity level",
          "scope": "window"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0"
  }
}
