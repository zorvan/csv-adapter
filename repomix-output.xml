            (Chain::Sui, NetworkType::Testnet),
            (Chain::Aptos, NetworkType::Testnet),
        ].into_iter().collect(),
    });

    use_context_provider(|| NetworkContext { state });
    
    rsx! {
        Outlet {}
    }
