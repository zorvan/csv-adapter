            .expect("Failed to parse response");

        let checkpoint = checkpoint_response["result"].clone();
        let epoch: u64 = checkpoint["epoch"]
            .as_str()
            .and_then(|s| s.parse().ok())
            .unwrap_or(0);

        println!("Epoch: {}", epoch);
        println!("✅ Sui Testnet is operational");
    }
