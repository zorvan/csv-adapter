{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CSV Proof",
  "scopeName": "source.csv-proof",
  "patterns": [
    {
      "include": "#csv-comments"
    },
    {
      "include": "#csv-annotations"
    },
    {
      "include": "#csv-identifiers"
    },
    {
      "include": "#csv-chains"
    },
    {
      "include": "#csv-proof-types"
    },
    {
      "include": "#csv-functions"
    },
    {
      "include": "#csv-strings"
    },
    {
      "include": "#csv-numbers"
    },
    {
      "include": "#csv-keywords"
    }
  ],
  "repository": {
    "csv-comments": {
      "patterns": [
        {
          "name": "comment.line.csv",
          "match": "//\\s*csv:\\s*(.*)",
          "captures": {
            "1": {
              "name": "storage.type.csv.annotation"
            }
          }
        },
        {
          "name": "comment.block.csv",
          "begin": "/\\*\\s*csv-adapter:",
          "end": "\\*/",
          "captures": {
            "0": {
              "name": "storage.type.csv.annotation"
            }
          }
        }
      ]
    },
    "csv-annotations": {
      "patterns": [
        {
          "name": "meta.annotation.csv",
          "match": "#\\[csv::([a-zA-Z_][a-zA-Z0-9_]*)\\]",
          "captures": {
            "1": {
              "name": "entity.name.function.csv"
            }
          }
        },
        {
          "name": "meta.annotation.csv",
          "match": "@csv\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.csv"
            }
          }
        }
      ]
    },
    "csv-identifiers": {
      "patterns": [
        {
          "name": "constant.other.right-id.csv",
          "match": "right_id[s]?:\\s*\"([a-fA-F0-9]{64})\"",
          "captures": {
            "1": {
              "name": "string.quoted.double.csv"
            }
          }
        },
        {
          "name": "constant.other.right-id.csv",
          "match": "RightId\\(\\s*\"([a-fA-F0-9]{64})\"\\s*\\)",
          "captures": {
            "1": {
              "name": "string.quoted.double.csv"
            }
          }
        },
        {
          "name": "variable.other.csv",
          "match": "\\b(right|proof|csv_client|transfer|chain_config)\\b"
        }
      ]
    },
    "csv-chains": {
      "patterns": [
        {
          "name": "support.constant.chain.csv",
          "match": "\\b(Ethereum|Bitcoin|Aptos|Sui|Solana|ethereum|bitcoin|aptos|sui|solana)\\b"
        },
        {
          "name": "support.constant.chain.csv",
          "match": "(EVM|BTC|APT|SUI|SOL)"
        }
      ]
    },
    "csv-proof-types": {
      "patterns": [
        {
          "name": "entity.name.type.csv",
          "match": "\\b(MerkleProof|SparseMerkleProof|ProofPath|Right|CsvClient|TransferRequest|ChainConfig|CrossChainProof|ProofVerifier|CsvError|CsvResult)\\b"
        }
      ]
    },
    "csv-functions": {
      "patterns": [
        {
          "name": "entity.name.function.csv",
          "match": "\\b(create_right|verify_proof|transfer_cross_chain|build_proof|get_balance|get_right|inspect_proof|init_csv|create_client|submit_proof|validate_right)\\b"
        }
      ]
    },
    "csv-strings": {
      "patterns": [
        {
          "name": "string.quoted.double.csv",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.csv",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.csv",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "csv-numbers": {
      "patterns": [
        {
          "name": "constant.numeric.csv",
          "match": "\\b(0x[a-fA-F0-9]+|\\d+(\\.\\d+)?(e[+-]?\\d+)?)\\b"
        }
      ]
    },
    "csv-keywords": {
      "patterns": [
        {
          "name": "keyword.control.csv",
          "match": "\\b(csv|proof|right|chain)\\b"
        }
      ]
    }
  }
}
