        &self,
        sequence_number: u64,
    ) -> Result<bool, Box<dyn std::error::Error + Send + Sync>>;

    fn as_any(&self) -> &dyn std::any::Any {
        unimplemented!("as_any() must be implemented by concrete types")
    }
}

