    let mut right_id = use_signal(|| String::new());
    let mut result = use_signal(|| Option::<String>::None);

    let proof_type = match *selected_chain.read() {
        Chain::Bitcoin => "merkle",
        Chain::Ethereum => "mpt",
        Chain::Sui => "checkpoint",
        Chain::Aptos => "ledger",
    };

    rsx! {
