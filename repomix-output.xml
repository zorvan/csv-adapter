        console.log(chalk.gray('  ║') + chalk.gray(' '.repeat(49)) + chalk.gray('║'));
        console.log(chalk.gray('  ║') + chalk.gray(' '.repeat(8)) + chalk.bold.red('🔐 PROOF SYSTEM MASTER! 🔐') + chalk.gray(' '.repeat(12)) + chalk.gray('║'));
        console.log(chalk.gray('  ║') + chalk.gray(' '.repeat(49)) + chalk.gray('║'));
        console.log(chalk.gray('  ║') + chalk.gray(' '.repeat(49)) + chalk.gray('║'));

