<file path="docs/csv-api.yaml">
openapi: 3.1.0
info:
  title: CSV Adapter API
  description: |
    Client-side validation system for cross-chain rights.
    
    This API enables AI agents and applications to:
    - Create and manage Rights anchored to blockchain seals
    - Execute cross-chain transfers with cryptographic proofs
    - Verify proofs locally without trusting intermediaries
    - Monitor wallet balances and chain status
    
    **Key Concepts:**
    - **Right**: A transferrable claim anchored to a chain's single-use seal
    - **Seal**: Chain-specific mechanism enforcing single-use (UTXO, Object, Resource, Nullifier)
    - **Cross-chain transfer**: Right moves by consuming seal on source, proving on destination
  version: 0.1.0
  contact:
    name: CSV Adapter Team
    url: https://github.com/zorvan/csv-adapter
  license:
    name: MIT OR Apache-2.0
    url: https://github.com/zorvan/csv-adapter/blob/main/LICENSE

servers:
  - url: http://localhost:3000/api/v1
    description: Local development server
  - url: https://api.csv.dev/v1
    description: Production API

tags:
  - name: rights
    description: Create, query, and manage Rights
  - name: transfers
    description: Cross-chain transfer operations
  - name: proofs
    description: Generate and verify cryptographic proofs
  - name: wallet
    description: Wallet and chain management

paths:
  /rights:
    post:
      operationId: createRight
      summary: Create a new Right
      description: Create a new Right anchored to a specific blockchain's single-use seal
      tags:
        - rights
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CreateRightRequest'
      responses:
        '201':
          description: Right created successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreateRightResponse'
        '400':
          description: Invalid request
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
    
    get:
      operationId: listRights
      summary: List all Rights
      description: List all Rights in the wallet, optionally filtered by chain and status
      tags:
        - rights
      parameters:
        - name: chain
          in: query
          description: Filter by chain
          schema:
            $ref: '#/components/schemas/Chain'
        - name: status
          in: query
          description: Filter by status
          schema:
            type: string
            enum: [active, spent, all]
            default: active
        - name: limit
          in: query
          description: Maximum number of Rights to return
          schema:
            type: integer
            default: 20
            maximum: 100
      responses:
        '200':
          description: List of Rights
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ListRightsResponse'

  /rights/{rightId}:
    get:
      operationId: getRight
      summary: Get Right details
      description: Get details of a specific Right by its ID
      tags:
        - rights
      parameters:
        - name: rightId
          in: path
          required: true
          description: The 32-byte Right ID (hex format)
          schema:
            type: string
            pattern: '^0x[a-fA-F0-9]{64}$'
      responses:
        '200':
          description: Right details
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GetRightResponse'
        '404':
          description: Right not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

  /transfers:
    post:
      operationId: createTransfer
      summary: Create cross-chain transfer
      description: |
        Transfer a Right from one blockchain to another.
        
        **Process:**
        1. Lock Right on source chain (consume seal)
        2. Generate cryptographic proof
        3. Submit proof to destination chain
        4. Mint Right on destination chain
      tags:
        - transfers
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CreateTransferRequest'
      responses:
        '201':
          description: Transfer initiated
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreateTransferResponse'
        '400':
          description: Invalid request
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
    
    get:
      operationId: listTransfers
      summary: List transfers
      description: List all cross-chain transfers, optionally filtered
      tags:
        - transfers
      parameters:
        - name: from_chain
          in: query
          description: Filter by source chain
          schema:
            $ref: '#/components/schemas/Chain'
        - name: to_chain
          in: query
          description: Filter by destination chain
          schema:
            $ref: '#/components/schemas/Chain'
        - name: status
          in: query
          description: Filter by status
          schema:
            type: string
            enum: [pending, completed, failed, all]
            default: all
        - name: limit
          in: query
          description: Maximum number of transfers to return
          schema:
            type: integer
            default: 20
            maximum: 100
      responses:
        '200':
          description: List of transfers
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ListTransfersResponse'

  /transfers/{transferId}:
    get:
      operationId: getTransfer
      summary: Get transfer status
      description: Get the current status of a cross-chain transfer
      tags:
        - transfers
      parameters:
        - name: transferId
          in: path
          required: true
          description: The transfer ID to check
          schema:
            type: string
            pattern: '^0x[a-fA-F0-9]{64}$'
      responses:
        '200':
          description: Transfer status
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GetTransferResponse'
        '404':
          description: Transfer not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

  /proofs/verify:
    post:
      operationId: verifyProof
      summary: Verify proof
      description: |
        Verify a cross-chain proof locally.
        
        This checks that a Right was properly locked on the source chain and the proof is valid.
      tags:
        - proofs
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/VerifyProofRequest'
      responses:
        '200':
          description: Proof verification result
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/VerifyProofResponse'

  /wallet/balance:
    get:
      operationId: getWalletBalance
      summary: Get wallet balance
      description: Check wallet balance across all supported blockchain chains
      tags:
        - wallet
      parameters:
        - name: chains
          in: query
          description: Comma-separated list of chains to check
          schema:
            type: string
            example: "bitcoin,ethereum"
      responses:
        '200':
          description: Wallet balances
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GetBalanceResponse'

  /wallet/chains:
    get:
      operationId: listChains
      summary: List supported chains
      description: List all supported blockchain chains and their current status
      tags:
        - wallet
      responses:
        '200':
          description: List of chains
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ListChainsResponse'

components:
  schemas:
    Chain:
      type: string
      enum:
        - bitcoin
        - ethereum
        - sui
        - aptos
      description: Supported blockchain networks

    CreateRightRequest:
      type: object
      required:
        - chain
        - commitment_data
      properties:
        chain:
          $ref: '#/components/schemas/Chain'
        commitment_data:
          type: object
          description: Data to commit (will be hashed)
          additionalProperties: true
