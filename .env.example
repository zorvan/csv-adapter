# CSV Adapter - Environment Variables
# Copy this file to .env and fill in your private keys.
# ⚠️  NEVER commit .env to version control!

# Bitcoin Signet wallet seed (128 hex chars for BIP-39 seed)
# Source: wallet/bitcoin-test.txt
BTC_SEED_HEX=

# Sui Testnet private key (64 hex chars, Ed25519)
# Source: wallet/sui-test.txt
SUI_PRIVATE_KEY=

# Aptos Testnet private key (64 hex chars, Ed25519)
# Source: wallet/aptos-test.txt
APTOS_PRIVATE_KEY=
