                        </div>
                    `).join('')}
                </div>
                <div class="card rounded-xl p-6">
                    <h3 class="text-lg font-semibold mb-4">Active Seals by Chain</h3>
                    ${stats.active_seals_by_chain.map(sc => `
                        <div class="flex justify-between mb-2">
                            <span>${createChainBadge(sc.chain)}</span>
                            <span class="font-mono">${sc.count}</span>
                        </div>
                    `).join('')}
                </div>
            `;
        }

        // ==================== Helpers ====================
        function getTimeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return 'Just now';
            if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;
            if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;
            return `${Math.floor(seconds / 86400)}d ago`;
        }

        function getStatusClass(type, status) {
            const s = status.toLowerCase();
            if (s === 'active' || s === 'completed' || s === 'available') return 'badge-active';
            if (s === 'spent' || s === 'failed' || s === 'consumed') return 'badge-spent';
            if (s === 'pending' || s === 'in_progress') return 'badge-pending';
            return 'bg-gray-800 text-gray-400';
        }

        // ==================== Real-time Updates ====================
        let updateInterval;

        function startRealTimeUpdates() {
            // Poll for updates every 30 seconds
            updateInterval = setInterval(() => {
                if (currentPage === 'home') {
                    loadActivity();
                    checkHealth();
                }
            }, 30000);
        }

        // ==================== Initialize ====================
        initNetwork();
        checkHealth();
        startRealTimeUpdates();
    </script>
</body>
</html>
