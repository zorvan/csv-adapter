        // Helper to get explorer URL for current network
        function getExplorerUrl(chain, type, hash) {
            const chainExplorers = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!chainExplorers) return '#';
            const explorer = chainExplorers[currentNetwork] || chainExplorers.mainnet;
            return explorer[type] ? explorer[type](hash) : '#';
        }
        
        function getExplorerName(chain) {
            const chainExplorers = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!chainExplorers) return chain;
            const explorer = chainExplorers[currentNetwork] || chainExplorers.mainnet;
            return explorer.name;
        }
        
        function getExplorerIcon(chain) {
            const chainExplorers = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!chainExplorers) return '●';
            const explorer = chainExplorers[currentNetwork] || chainExplorers.mainnet;
            return explorer.icon;
        }
        
        function getExplorerColor(chain) {
            const chainExplorers = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!chainExplorers) return '#6b7280';
            const explorer = chainExplorers[currentNetwork] || chainExplorers.mainnet;
            return explorer.color;
        }

        // ==================== Navigation ====================
        let currentPage = 'home';
        let searchQuery = '';
        let searchFilter = 'all';

        function showPage(page, params = {}) {
            // Hide all pages
            document.querySelectorAll('[id^="page-"]').forEach(el => el.classList.add('hidden'));
            
            // Show target page
            const targetPage = document.getElementById(`page-${page}`);
            if (targetPage) {
                targetPage.classList.remove('hidden');
            }
            
            // Update nav links
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
                if (link.dataset.page === page) {
                    link.classList.add('active');
                }
            });
            
            currentPage = page;
            
            // Load data for page
            if (page.startsWith('right-detail') && params.id) {
                loadRightDetail(params.id);
            } else if (page.startsWith('transfer-detail') && params.id) {
                loadTransferDetail(params.id);
            } else if (page.startsWith('seal-detail') && params.id) {
                loadSealDetail(params.id);
            } else if (page.startsWith('contract-detail') && params.id) {
                loadContractDetail(params.id);
            } else {
                loadData(page);
            }
            
            // Scroll to top
            window.scrollTo(0, 0);
        }

        // ==================== Data Loading ====================
        async function loadData(page) {
            try {
                switch(page) {
                    case 'home': await loadHome(); break;
                    case 'rights': await loadRights(); break;
                    case 'transfers': await loadTransfers(); break;
                    case 'seals': await loadSeals(); break;
                    case 'contracts': await loadContracts(); break;
                    case 'stats': await loadStats(); break;
                }
            } catch (error) {
                console.error(`Error loading ${page}:`, error);
                showToast('Failed to load data', 'error');
            }
        }

        // ==================== Copy to Clipboard ====================
        async function copyToClipboard(text, label = 'ID') {
            try {
                await navigator.clipboard.writeText(text);
                showToast(`${label} copied to clipboard!`, 'success');
            } catch (err) {
                // Fallback for older browsers
                const textarea = document.createElement('textarea');
                textarea.value = text;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                document.body.removeChild(textarea);
                showToast(`${label} copied to clipboard!`, 'success');
            }
        }

        function createCopyButton(id, label = 'ID') {
            return `<button onclick="copyToClipboard('${id}', '${label}')" 
                            class="copy-btn ml-2 p-1 bg-gray-700 hover:bg-gray-600 rounded text-xs transition-all"
                            title="Copy ${label}">
                        📋
                    </button>`;
        }

        // ==================== External Explorer Links ====================
        function createExplorerLink(chain, type, hash) {
            const explorer = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!explorer) return hash;
            
            const url = explorer[type](hash);
            return `<a href="${url}" target="_blank" 
                        class="text-blue-400 hover:text-blue-300 underline flex items-center gap-1"
                        title="View on ${explorer.name} Explorer">
                        ${hash.substring(0, 20)}...
                        <span class="text-xs">↗</span>
                    </a>`;
        }

        function createChainBadge(chain) {
            const color = getExplorerColor(chain);
            const icon = getExplorerIcon(chain);
            return `<span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium" 
                          style="background-color: ${color}20; color: ${color}">
                        ${icon} ${chain}
                    </span>`;
        }

        // ==================== Toast Notifications ====================
        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const colors = {
                success: 'bg-green-600',
                error: 'bg-red-600',
                info: 'bg-blue-600',
                warning: 'bg-yellow-600'
            };
            
            const toast = document.createElement('div');
            toast.className = `${colors[type]} text-white px-6 py-3 rounded-lg shadow-lg mb-2`;
            toast.textContent = message;
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(() => container.removeChild(toast), 300);
            }, 3000);
        }

        // ==================== Search ====================
        function performSearch() {
            searchQuery = document.getElementById('global-search').value.trim().toLowerCase();
            searchFilter = document.getElementById('search-filter').value;
            
            const infoDiv = document.getElementById('search-results-info');
            if (searchQuery) {
                infoDiv.classList.remove('hidden');
                infoDiv.innerHTML = `Searching for: <span class="text-blue-400">${searchQuery}</span>`;
                
                // Search across all data types
                searchAllData();
            } else {
                infoDiv.classList.add('hidden');
            }
        }

        function clearSearch() {
            document.getElementById('global-search').value = '';
            document.getElementById('search-filter').value = 'all';
            document.getElementById('search-results-info').classList.add('hidden');
            searchQuery = '';
            searchFilter = 'all';
            showPage('home');
        }

        async function searchAllData() {
            try {
                const [rightsResp, transfersResp, sealsResp] = await Promise.all([
                    fetch(`${API_URL}/api/v1/rights?limit=100`),
                    fetch(`${API_URL}/api/v1/transfers?limit=100`),
                    fetch(`${API_URL}/api/v1/seals?limit=100`)
                ]);
                
                const rights = (await rightsResp.json()).data.data || [];
                const transfers = (await transfersResp.json()).data.data || [];
                const seals = (await sealsResp.json()).data.data || [];
                
                let results = [];
                
                // Filter and search rights
                results = results.concat(rights.filter(r => 
                    matchesSearch(r) && matchesChainFilter(r.chain)
                ).map(r => ({
                    type: 'Right',
                    id: r.id,
                    title: `Right: ${r.id.substring(0, 20)}...`,
                    chain: r.chain,
                    status: r.status,
                    page: 'right-detail',
                    params: { id: r.id }
                })));
                
                // Filter and search transfers
                results = results.concat(transfers.filter(t => 
                    matchesSearch(t) && matchesChainFilter(t.from_chain)
                ).map(t => ({
                    type: 'Transfer',
                    id: t.id,
                    title: `Transfer: ${t.from_chain} → ${t.to_chain}`,
                    chain: t.from_chain,
                    status: t.status,
                    page: 'transfer-detail',
                    params: { id: t.id }
                })));
                
                // Filter and search seals
                results = results.concat(seals.filter(s => 
                    matchesSearch(s) && matchesChainFilter(s.chain)
                ).map(s => ({
                    type: 'Seal',
                    id: s.id,
                    title: `Seal: ${s.id.substring(0, 20)}...`,
                    chain: s.chain,
                    status: s.status,
                    page: 'seal-detail',
                    params: { id: s.id }
                })));
                
                // Display results
                displaySearchResults(results);
                
            } catch (error) {
                console.error('Search failed:', error);
                showToast('Search failed', 'error');
            }
        }

        function matchesSearch(item) {
            if (!searchQuery) return true;
            const searchable = JSON.stringify(item).toLowerCase();
            return searchable.includes(searchQuery);
        }

        function matchesChainFilter(chain) {
            if (searchFilter === 'all') return true;
            return chain.toLowerCase() === searchFilter;
        }

        function displaySearchResults(results) {
            const infoDiv = document.getElementById('search-results-info');
            infoDiv.innerHTML = `Found <span class="text-blue-400">${results.length}</span> results for: <span class="text-blue-400">${searchQuery}</span>`;
            
            // Create results page if needed
            if (!document.getElementById('page-search-results')) {
                const main = document.querySelector('main');
                const resultsPage = document.createElement('div');
                resultsPage.id = 'page-search-results';
                resultsPage.className = 'hidden';
                main.appendChild(resultsPage);
            }
            
            const resultsDiv = document.getElementById('search-results-content') || document.createElement('div');
            resultsDiv.id = 'search-results-content';
            resultsDiv.className = 'space-y-4';
            
            if (results.length === 0) {
                resultsDiv.innerHTML = '<div class="card rounded-xl p-8 text-center text-gray-400">No results found</div>';
            } else {
                resultsDiv.innerHTML = results.map(r => `
                    <div class="card rounded-xl p-4 clickable hover:bg-gray-800/50 transition-colors" 
                         onclick="showPage('${r.page}', ${JSON.stringify(r.params).replace(/"/g, '&quot;')})">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-medium">${r.type}</span>
                                    ${createChainBadge(r.chain)}
                                    <span class="badge badge-${r.status}">${r.status}</span>
                                </div>
                                <div class="text-sm text-gray-400">${r.title}</div>
                            </div>
                            <span class="text-blue-400">→</span>
                        </div>
                    </div>
                `).join('');
            }
            
            document.getElementById('page-search-results').innerHTML = `
                <div class="mb-6">
                    <button onclick="clearSearch()" class="text-blue-400 hover:text-blue-300 mb-4">← Clear Search</button>
                    <h2 class="text-2xl font-bold mb-4">Search Results</h2>
                </div>
                ${resultsDiv.outerHTML}
            `;
            
            showPage('search-results');
        }

