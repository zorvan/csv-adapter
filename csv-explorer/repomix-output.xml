#[component]
fn RightRow(id: String, chain: String, owner: String, status: String, created_at: chrono::DateTime<chrono::Utc>, transfer_count: u64) -> Element {
    rsx! {
        tr { class: "hover:bg-gray-800/50 transition-colors",
            td { class: "px-6 py-4",
                Link {
                    to: Route::RightDetail { id: id.clone() },
                    class: "font-mono text-sm text-blue-400 hover:text-blue-300",
                    "{id}"
                }
            }
            td { class: "px-6 py-4",
                ChainBadge { chain }
            }
            td { class: "px-6 py-4 font-mono text-sm text-gray-300",
                "{owner}"
            }
            td { class: "px-6 py-4",
                crate::components::status_badge::StatusBadge { status }
            }
            td { class: "px-6 py-4 text-sm text-gray-400",
                "{format_datetime(created_at)}"
            }
            td { class: "px-6 py-4 text-sm text-gray-300",
                "{transfer_count}"
            }
        }
    }
}

fn format_datetime(dt: chrono::DateTime<chrono::Utc>) -> String {
    let now = chrono::Utc::now();
    let diff = (now - dt).num_seconds();
    if diff < 60 {
        format!("{}s ago", diff)
    } else if diff < 3600 {
        format!("{}m ago", diff / 60)
    } else if diff < 86400 {
        format!("{}h ago", diff / 3600)
    } else {
        format!("{}d ago", diff / 86400)
    }
}
