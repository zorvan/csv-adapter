                const transfers = transfersJson.data.data || [];
                const seals = sealsJson.data.data || [];

                const activities = [
                    ...rights.map(r => ({
                        type: 'right',
                        icon: '📜',
                        title: `Right Created`,
                        subtitle: r.id,
                        chain: r.chain,
                        status: r.status,
                        time: new Date(r.created_at),
                        details: `Owner: ${r.owner.substring(0, 20)}...`,
                        page: 'right-detail',
                        params: { id: r.id }
