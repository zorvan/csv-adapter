        let gql_ctx = ctx.data::<GraphqlContext>().map_err(|e| ServerError::new(format!("{:?}", e), None))?;
        let repo = SealsRepository::new(gql_ctx.pool.clone());

        let filter = filter.unwrap_or_default();
