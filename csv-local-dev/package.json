{
  "name": "csv-local-dev",
  "version": "1.0.0",
  "description": "Local chain simulator for CSV Adapter - enables the 5-minute rule",
  "main": "src/index.js",
  "bin": {
    "csv-local": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js start",
    "status": "node src/index.js status",
    "stop": "node src/index.js stop",
    "reset": "node src/index.js reset",
    "dev": "node src/index.js start --chains all --fast-mode"
  },
  "keywords": [
    "csv",
    "blockchain",
    "simulator",
    "local-dev",
    "bitcoin",
    "ethereum",
    "sui",
    "aptos"
  ],
  "author": "CSV Adapter Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
