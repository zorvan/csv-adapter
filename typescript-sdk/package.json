{
  "name": "@csv-adapter/sdk",
  "version": "0.4.0",
  "description": "TypeScript SDK for Client-Side Validation (CSV) Protocol — cross-chain digital sanads with single-use seals",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./wasm": {
      "import": "./wasm/pkg/csv_crypto_wasm.js",
      "require": "./wasm/pkg/csv_crypto_wasm.js",
      "types": "./wasm/pkg/csv_crypto_wasm.d.ts"
    }
  },
  "files": [
    "dist",
    "wasm",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:wasm": "wasm-pack build wasm --target web --dev",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/ --ext .ts",
    "prepublishOnly": "npm run build && npm run build:wasm"
  },
  "keywords": [
    "csv",
    "client-side-validation",
    "blockchain",
    "cross-chain",
    "digital-sanads",
    "nft",
    "seal",
    "proof",
    "zero-knowledge"
  ],
  "author": "Amin Razavi",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/client-side-validation/csv-adapter"
  },
  "bugs": {
    "url": "https://github.com/client-side-validation/csv-adapter/issues"
  },
  "homepage": "https://github.com/client-side-validation/csv-adapter",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "wasm-pack": "^0.13"
  },
  "dependencies": {
    "@noble/hashes": "^1.3.0",
    "@noble/curves": "^1.2.0",
    "bs58": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
